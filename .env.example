# EdgeFlow – single .env at repo root (copy to .env and adjust)

# Bridge WebSocket port (core) – default 19707 to avoid conflicts with other tools on 7070
BRIDGE_PORT=19707

# Bridge URL for the example-kiosk app (must match BRIDGE_PORT if you change it)
VITE_BRIDGE_URL=ws://localhost:19707

# Sync sink URL – POST endpoint for outbox events (optional; without it, events stay pending)
# SYNC_SINK_URL=https://your-api.com/events

# OTA manifest URL – JSON with version, entrypoint, sha256 (optional)
# OTA_MANIFEST_URL=https://your-server.com/ota/manifest.json

# Force in-memory sync store (skip SQLite). Use if better-sqlite3 fails on Windows.
# SYNC_STORE=memory
