  },
  "devDependencies": {
    "@edgeflowjs/cli": "^0.2.0",
    "concurrently": "^9.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.1"
