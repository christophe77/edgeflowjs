{
  "name": "@edgeflowjs/core",
  "version": "0.1.0",
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "node dist/run.js",
    "start": "node dist/run.js"
  },
  "dependencies": {
    "@edgeflowjs/bridge": "workspace:*",
    "@edgeflowjs/device": "workspace:*",
    "@edgeflowjs/device-rpi": "workspace:*",
    "@edgeflowjs/device-sim": "workspace:*",
    "@edgeflowjs/flow": "workspace:*",
    "@edgeflowjs/maintenance": "workspace:*",
    "@edgeflowjs/observability": "workspace:*",
    "@edgeflowjs/ota": "workspace:*",
    "@edgeflowjs/sync": "workspace:*",
    "better-sqlite3": "^11.6.0",
    "dotenv": "^17.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
